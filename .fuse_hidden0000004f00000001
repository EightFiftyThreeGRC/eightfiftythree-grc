<!-- Save / export / import (left of reset) — survives refresh via localStorage + file backup -->
<div id="app-persist-toolbar" style="position:fixed; top:14px; right:200px; z-index:1100; display:flex; align-items:center; gap:8px; flex-wrap:wrap; max-width:calc(100vw - 280px); justify-content:flex-end;">
  <span id="saveIndicator" style="font-size:11px; font-weight:600; color:var(--text-muted); padding:4px 10px; background:white; border:1px solid #e2e8f0; border-radius:20px; box-shadow:0 1px 4px rgba(0,0,0,0.06);">✓ Saved</span>
  <button type="button" class="btn btn-secondary" onclick="saveToStorage()" title="Write current program to this browser (auto-saves after edits)" style="padding:6px 12px; font-size:12px; font-weight:600; border-radius:20px; box-shadow:0 1px 4px rgba(0,0,0,0.06);">💾 Save now</button>
  <button type="button" class="btn btn-secondary" onclick="exportProgramJson()" title="Download all program data as JSON" style="padding:6px 12px; font-size:12px; font-weight:600; border-radius:20px; box-shadow:0 1px 4px rgba(0,0,0,0.06);">⬇ Export</button>
  <button type="button" class="btn btn-secondary" onclick="document.getElementById('importProgramInput').click()" title="Restore from a previously exported JSON file" style="padding:6px 12px; font-size:12px; font-weight:600; border-radius:20px; box-shadow:0 1px 4px rgba(0,0,0,0.06);">⬆ Import</button>
  <input type="file" id="importProgramInput" accept="application/json,.json" style="display:none;" onchange="importProgramFromFile(event)">
</div>

<!-- RESET BUTTON (top-right corner) -->
<button id="resetBtn" onclick="confirmReset()"
  title="Reset all programme data"
  style="position:fixed; top:14px; right:20px; z-index:1100;
    display:flex; align-items:center; gap:6px;
    background:white; color:#64748b;
    border:1px solid #e2e8f0; border-radius:20px;
    padding:6px 14px; font-size:12px; font-weight:600; cursor:pointer;
    transition:all 0.2s; letter-spacing:0.3px;
    box-shadow:0 1px 4px rgba(0,0,0,0.08);"
  onmouseenter="this.style.background='#fef2f2'; this.style.color='#dc2626'; this.style.borderColor='#fca5a5';"
  onmouseleave="this.style.background='white'; this.style.color='#64748b'; this.style.borderColor='#e2e8f0';">
  ↺ Reset
</button>

